{
  "version": 2,
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": false
    }
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 10,
      "includeFiles": "dist/client/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/process-recurring",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/monthly-alerts",
      "schedule": "0 9 1 * *"
    }
  ]
}
